# Base URL of the FastAPI backend (Hugging Face Spaces, etc.)
# Leave unset while developing against the built-in mock.
NEXT_PUBLIC_API_BASE_URL=

# Set to "true" to force mock mode even if NEXT_PUBLIC_API_BASE_URL is set.
# Mock mode is also the automatic fallback whenever NEXT_PUBLIC_API_BASE_URL is empty.
NEXT_PUBLIC_USE_MOCK=true
