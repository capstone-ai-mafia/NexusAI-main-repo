# Backend
DATABASE_URL=sqlite:////app/data/nexus_ai.db
UPLOAD_DIR=/app/data/uploads
LOG_DIR=/app/data/logs
CHROMA_PATH=/app/data/chroma_db
HF_HOME=/app/data/hf_cache

# LLM generation (Ollama)
# llama3.1:8b is stronger if your GPU/CPU has the memory for it; llama3.2:3b
# is the default here because it fits comfortably on a memory-constrained
# (e.g. 4GB) GPU and answers reliably for this RAG use case.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=180
MAX_CONTEXT_TOKENS=3500

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://backend:8000
NEXT_PUBLIC_USE_MOCK=false
